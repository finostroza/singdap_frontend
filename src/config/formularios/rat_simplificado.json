{
    "sections": [
        {
            "title": "1. Identificación general del tratamiento",
            "description": "Antecedentes principales para individualizar el tratamiento y sus responsables.",
            "fields": [
                {
                    "key": "nombre_tratamiento",
                    "label": "Nombre del tratamiento",
                    "description": "Ingrese denominación del tratamiento de datos personales.",
                    "type": "text",
                    "required": true
                },
                {
                    "key": "tipo_tratamiento",
                    "label": "Tipo de tratamiento",
                    "description": "Seleccione el tipo de tratamiento (seleccione solo 1 de las opciones)",
                    "type": "combo",
                    "source": "/catalogos/rat/tipo-tratamiento",
                    "cache_key": "catalogo_rat_tipo_tratamiento",
                    "required": true
                },
                {
                    "key": "subsecretaria",
                    "label": "Subsecretaria",
                    "description": "Seleccione la unidad responsable.",
                    "type": "combo",
                    "source": "/setup/subsecretarias",
                    "cache_key": "catalogo_subsecretarias",
                    "triggers_reload": [
                        "division"
                    ],
                    "required": true
                },
                {
                    "key": "division",
                    "label": "División",
                    "description": "División organizacional a la cual se adscribe el responsable.",
                    "type": "combo",
                    "cache_key": "catalogo_divisiones_v2",
                    "depends_on": "subsecretaria",
                    "dependency_endpoint_template": "/setup/divisiones?subsecretaria_id={value}",
                    "triggers_reload": [
                        "departamento"
                    ],
                    "required": true
                },
                {
                    "key": "departamento",
                    "label": "Departamento",
                    "type": "combo",
                    "cache_key": "catalogo_departamentos_v2",
                    "depends_on": "division",
                    "dependency_endpoint_template": "/setup/departamentos?division_id={value}",
                    "required": true
                },
                {
                    "key": "nombre_responsable",
                    "label": "Nombre Responsable del tratamiento",
                    "description": "Indique 1 encargado (persona y datos de contacto).",
                    "type": "text",
                    "required": true
                },
                {
                    "key": "cargo_responsable",
                    "label": "Cargo responsable del tratamiento",
                    "type": "text",
                    "required": true
                },
                {
                    "key": "email_responsable",
                    "label": "Email responsable del tratamiento",
                    "type": "text",
                    "required": true
                },
                {
                    "key": "telefono_responsable",
                    "label": "Teléfono responsable del tratamiento",
                    "type": "text",
                    "required": true
                },
                {
                    "key": "nombre_encargado",
                    "label": "Nombre Encargado(s) del tratamiento",
                    "description": "Indique 1 o más encargados (personas/unidades) según corresponda.",
                    "type": "text",
                    "required": true
                },
                {
                    "key": "cargo_encargado",
                    "label": "Cargo encargado del tratamiento",
                    "type": "text",
                    "required": true
                },
                {
                    "key": "email_encargado",
                    "label": "Email encargado del tratamiento",
                    "type": "text",
                    "required": true
                },
                {
                    "key": "telefono_encargado",
                    "label": "Telefono encargado del tratamiento",
                    "type": "text",
                    "required": true
                }
            ]
        },
        {
            "title": "2. Descripción del tratamiento",
            "description": "Defina el tratamiento con el alcance claro.",
            "fields": [
                {
                    "key": "autorizacion_datos_ris",
                    "label": "Autorización de datos RIS o RISE",
                    "description": "Seleccione la autorización de datos RIS que corresponde a este tratamiento.",
                    "type": "combo",
                    "source": "/catalogos/rat/autorizacion-datos",
                    "cache_key": "catalogo_rat_autorizacion_datos",
                    "required": true
                },
                {
                    "key": "descripcion_alcance",
                    "label": "Descripción y alcance",
                    "description": "Defina el tratamiento con el alcance claro.",
                    "type": "textarea",
                    "required": true
                },
                {
                    "key": "operaciones_realizadas",
                    "label": "Operaciones realizadas",
                    "description": "Describa claramente las operaciones involucradas, por ejemplo, cómo prepara los datos, cómo se extraen...",
                    "type": "textarea",
                    "required": true
                },
                {
                    "key": "equipos_involucrados",
                    "label": "Equipos que realizan las operaciones de tratamiento descritas",
                    "description": "Ingrese el nombre de los equipos involucrados en el tratamiento, debe ser uno como mínimo.",
                    "type": "textarea",
                    "required": true
                },
                {
                    "key": "software_utilizado",
                    "label": "Aplicaciones/software que utiliza para el tratamiento",
                    "description": "Pueden ser software como SPSS, STATA, Python, otros. Mencione si utiliza cuadernos de jupiter.",
                    "type": "textarea",
                    "required": true
                },
                {
                    "key": "repositorios_utilizados",
                    "label": "Repositorios utilizados",
                    "description": "Considerando los repositorios de almacenamiento, así como donde se alojan los códigos.",
                    "type": "textarea",
                    "required": true
                },
                {
                    "key": "sistemas_plataformas",
                    "label": "Sistemas y plataformas involucradas",
                    "description": "Liste o describe los sistemas y plataformas involucrados.",
                    "type": "textarea",
                    "required": true
                },
                {
                    "key": "archivos_adjuntos",
                    "label": "Adjunte archivos que faciliten el entendimiento del tratamiento",
                    "description": "Cargue los archivos que apoyen la descripción del tratamiento.",
                    "type": "file",
                    "required": true
                },
                {
                    "key": "mecanismo_habilitante",
                    "label": "Mecanismo habilitante del tratamiento",
                    "description": "Normativa aplicable al tratamiento (Ley, decretos e instrucción administrativa, otros).",
                    "type": "combo",
                    "source": "/catalogos/marco-habilitante",
                    "cache_key": "catalogo_marco_habilitante_rat",
                    "required": true
                },
                {
                    "key": "nombre_mecanismo",
                    "label": "Nombre mecanismo",
                    "type": "text",
                    "required": true
                },
                {
                    "key": "consentimiento_titular",
                    "label": "Consentimiento del titular o habilitación legal",
                    "description": "Seleccione la opción que corresponda al tratamiento de datos.",
                    "type": "combo",
                    "source": "/catalogos/rat/consentimiento-titular",
                    "cache_key": "catalogo_rat_consentimiento_titular",
                    "required": true
                },
                {
                    "key": "finalidad_tratamiento",
                    "label": "Finalidad del tratamiento",
                    "description": "Describir el propósito y fin último del tratamiento.",
                    "type": "textarea",
                    "required": true
                },
                {
                    "key": "categorias_destinatarios",
                    "label": "Categorías de destinatarios",
                    "type": "combo",
                    "source": "/catalogos/rat/categoria-destinatarios",
                    "cache_key": "catalogo_rat_categoria_destinatarios",
                    "required": true
                }
            ]
        },
        {
            "title": "3. Titulares de los datos",
            "description": "Identificación de los titulares de la información.",
            "fields": [
                {
                    "key": "categorias_datos_personales",
                    "label": "Categorías de datos personales tratados",
                    "description": "Seleccione la o las opciones que correspondan al tratamiento de datos (Selección multiple).",
                    "type": "combo",
                    "multiple": true,
                    "source": "/catalogos/rat/categoria-datos-personales",
                    "cache_key": "catalogo_rat_categoria_datos_personales_v2",
                    "triggers_reload": [
                        "categorias_datos_sensibles"
                    ],
                    "required": true
                },
                {
                    "key": "categorias_datos_sensibles",
                    "label": "Especificación de datos sensibles",
                    "description": "Especifique el tipo de dato personal sensible contenido en el tratamiento.",
                    "type": "combo",
                    "multiple": true,
                    "depends_on": "categorias_datos_personales",
                    "depends_type": "nested",
                    "nested_key": "subcategorias",
                    "required": true,
                    "visible_when": {
                        "field": "categorias_datos_personales",
                        "contains": "Datos sensibles"
                    }
                },
                {
                    "key": "categorias_datos_otro",
                    "label": "Especifique Otro tipo de dato",
                    "description": "Indique la naturaleza de los otros datos personales tratados.",
                    "type": "text",
                    "required": true,
                    "visible_when": {
                        "field": "categorias_datos_sensibles",
                        "contains": "Otros datos personales"
                    }
                },
                {
                    "key": "poblaciones_vulnerables",
                    "label": "Poblaciones especiales o grupos vulnerables",
                    "description": "Seleccione la o las opciones que correspondan al tratamiento de datos (Selección multiple).",
                    "type": "combo",
                    "multiple": true,
                    "source": "/catalogos/rat/poblacion-especial",
                    "cache_key": "catalogo_rat_poblacion-especial",
                    "required": true
                },
                {
                    "key": "poblaciones_vulnerables_otro",
                    "label": "Especifique Otra población o grupo",
                    "description": "Indique la naturaleza del grupo vulnerable no listado.",
                    "type": "text",
                    "required": true,
                    "visible_when": {
                        "field": "poblaciones_vulnerables",
                        "contains": "Otra"
                    }
                },
                {
                    "key": "tipos_datos",
                    "label": "Tipos de datos",
                    "description": "Marque la opción que corresponda.",
                    "type": "combo",
                    "source": "/catalogos/rat/tipo-datos",
                    "cache_key": "catalogo_rat_tipo_datos",
                    "required": true
                },
                {
                    "key": "origen_datos",
                    "label": "Origen de datos",
                    "description": "Seleccione la o las bases de datos del RIS y los medios de recolección.",
                    "type": "combo",
                    "source": "/catalogos/rat/origen-datos",
                    "cache_key": "catalogo_rat_origen_datos",
                    "required": true
                },
                {
                    "key": "activo_id",
                    "label": "Seleccione Activo del Inventario",
                    "type": "combo",
                    "multiple": true,
                    "source": "/activos/catalogos",
                    "cache_key": "catalogo_inventario_activos",
                    "required": true,
                    "visible_when": {
                        "field": "origen_datos",
                        "contains": "Inventario"
                    }
                },
                {
                    "key": "medio_recoleccion",
                    "label": "Medio recoleccion",
                    "type": "combo",
                    "source": "/catalogos/rat/medio-recoleccion",
                    "cache_key": "catalogo_rat_medio_recoleccion_simp",
                    "required": true,
                    "visible_when": {
                        "field": "origen_datos",
                        "contains": "Otra"
                    }
                },
                {
                    "key": "medio_recoleccion_otro",
                    "label": "Especifique el Medio de recolección",
                    "type": "text",
                    "required": true,
                    "visible_when": {
                        "field": "medio_recoleccion",
                        "contains": "Otra"
                    }
                },
                {
                    "key": "volumen_datos",
                    "label": "Volumen aproximado de datos",
                    "description": "Ingrese un valor aproximado o estimación del número de registros involucrados y del número de archivos.",
                    "type": "text",
                    "required": true
                },
                {
                    "key": "cantidad_archivos",
                    "label": "Cantidad de archivos involucrados (approx.)",
                    "type": "text",
                    "required": true
                },
                {
                    "key": "decisiones_automatizadas",
                    "label": "El tratamiento considera decisiones individuales automatizadas",
                    "description": "Marque la opción que corresponda.",
                    "type": "combo_static",
                    "options": [
                        {
                            "id": "si",
                            "nombre": "Sí"
                        },
                        {
                            "id": "no",
                            "nombre": "No"
                        }
                    ],
                    "required": true
                }
            ]
        },
        {
            "title": "4. Identificación Inicial de riesgos",
            "description": "Identificación preliminar de riesgos del tratamiento.",
            "fields": [
                {
                    "key": "riesgos_identificados",
                    "label": "Riesgos Identificados",
                    "description": "Agregue una fila por cada riesgo identificado.",
                    "type": "editable_table",
                    "columns": [
                        {
                            "key": "nombre_riesgo",
                            "label": "Nombre del Riesgo"
                        },
                        {
                            "key": "descripcion_riesgo",
                            "label": "Descripción del Riesgo"
                        }
                    ],
                    "required": true
                }
            ]
        },
        {
            "title": "5. Conclusión",
            "description": "Conclusión general del RAT.",
            "fields": [
                {
                    "key": "sintesis_analisis",
                    "label": "Síntesis del análisis",
                    "description": "Conclusión general del RAT.",
                    "type": "text",
                    "required": true
                },
                {
                    "key": "corresponde_eipd",
                    "label": "¿Corresponde aplicar EIPD?",
                    "description": "Determinación formal.",
                    "type": "combo_static",
                    "options": [
                        {
                            "id": "si_corresponde",
                            "nombre": "Sí, corresponde la aplicación de una EIPD"
                        },
                        {
                            "id": "no_requiere",
                            "nombre": "No, no requiere la aplicación de una EIPD"
                        }
                    ],
                    "required": true
                },
                {
                    "key": "justificacion",
                    "label": "Justificación",
                    "description": "Fundamento técnico y normativo de la decisión.",
                    "type": "textarea",
                    "required": true
                }
            ]
        },
        {
            "title": "11. Gobierno de Datos",
            "description": "Metadatos del documento RAT.",
            "fields": [
                {
                    "key": "fecha_elaboracion",
                    "label": "Fecha de elaboración",
                    "type": "text",
                    "control": "calendar",
                    "required": true
                },
                {
                    "key": "responsable_informe",
                    "label": "Responsable del Informe",
                    "type": "text",
                    "required": true
                },
                {
                    "key": "equipo_entrevistados",
                    "label": "Equipo de entrevistados",
                    "type": "text",
                    "required": true
                },
                {
                    "key": "equipo_validacion",
                    "label": "Equipo de validación de contenidos",
                    "type": "text",
                    "required": true
                },
                {
                    "key": "revision_aprobacion",
                    "label": "Revisión y aprobación final",
                    "type": "text",
                    "required": true
                }
            ]
        }
    ]
}
